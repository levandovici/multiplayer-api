## Error Test Cases

### Invalid API Token Test
```bash
curl -X GET "https://api.michitai.com/unity/game_data.php/game/get?api_token=INVALID_TOKEN" \
  -H "Content-Type: application/json"
```

**Expected Response**:
```json
{
    "success": false,
    "error": "Invalid API token"
}
```

### Missing Player Token Test
```bash
curl -X GET "https://api.michitai.com/unity/game_data.php/player/get?api_token=YOUR_API_TOKEN" \
  -H "Content-Type: application/json"
```

**Expected Response**:
```json
{
    "success": false,
    "error": "Game player token is required"
}
```

### Invalid JSON Test
```bash
curl -X POST "https://api.michitai.com/unity/game_players.php/register?api_token=YOUR_API_TOKEN" \
  -H "Content-Type: application/json" \
  -d '{"invalid":json}'
```

**Expected Response**:
```json
{
    "success": false,
    "error": "Invalid JSON body"
}
```

### Method Not Allowed Test
```bash
curl -X DELETE "https://api.michitai.com/unity/time.php?api_token=YOUR_API_TOKEN" \
  -H "Content-Type: application/json"
```

**Expected Response**:
```json
{
    "success": false,
    "error": "Method not allowed",
    "allowed_methods": ["GET"]
}
```

## Unity SDK Integration Test

### Test Script for Unity
```csharp
using UnityEngine;
using MultiplayerAPI;

public class SDKTest : MonoBehaviour
{
    private MultiplayerSDK sdk;
    
    void Start()
    {
        sdk = gameObject.AddComponent<MultiplayerSDK>();
        sdk.SetApiToken("YOUR_API_TOKEN");
        
        // Test player registration
        TestPlayerRegistration();
        
        // Test game data
        TestGameData();
        
        // Test time
        TestServerTime();
    }
    
    void TestPlayerRegistration()
    {
        sdk.RegisterPlayer("TestPlayer", "{\"level\":1,\"score\":0}", (response) => {
            if (response.success) {
                Debug.Log("✅ Player registration test passed");
                Debug.Log($"Player ID: {response.player_id}");
                
                // Test login with returned token
                sdk.SetGamePlayerToken(response.private_key);
                TestPlayerLogin();
            } else {
                Debug.LogError("❌ Player registration test failed: " + response.error);
            }
        });
    }
    
    void TestPlayerLogin()
    {
        sdk.LoginPlayer((response) => {
            if (response.success) {
                Debug.Log("✅ Player login test passed");
                Debug.Log($"Player: {response.player.player_name}");
            } else {
                Debug.LogError("❌ Player login test failed: " + response.error);
            }
        });
    }
    
    void TestGameData()
    {
        sdk.GetGameData((response) => {
            if (response.success) {
                Debug.Log("✅ Game data test passed");
                var gameData = JsonUtility.FromJson<GameData>(response.data_json);
                Debug.Log($"Game data: {gameData}");
            } else {
                Debug.LogError("❌ Game data test failed: " + response.error);
            }
        });
    }
    
    void TestServerTime()
    {
        sdk.GetServerTime((response) => {
            if (response.success) {
                Debug.Log("✅ Server time test passed");
                Debug.Log($"Server time: {response.utc}");
            } else {
                Debug.LogError("❌ Server time test failed: " + response.error);
            }
        });
    }
}

[System.Serializable]
public class GameData
{
    public string difficulty;
    public int max_players;
}
```

